:: This batch file is expected to be run by script nurbs_benchmark_grid.bat
:: generated by CMake in build folder; path to that folder shall be stored
:: in environment variable %BUILD_PATH%.
::
:: Usage:
::
:: - by default (no arguments) runs standard tests using data files in "data" folder;
::   each file is tested with different options, overall 10 iterations for statistics
::   (use the lower CPU and elapsed time values among all runs as a measure)
::
:: - with single argument: probe all files in the folder specified by this argument,
::   outputting information on their surfaces and curves
::
:: - with multiple arguments: run benchmark with specified arguments
::
:: One-line digest of each execution of benchmark (arguments and times) is added to
:: file runs.log in the current folder.

set "DATA_DIR=%~dp0data"
set "EXE=%BUILD_PATH%\Release\nurbs_benchmark.exe"

setlocal enabledelayedexpansion

if "%1" == "" (
  set mode=test
) else if "%2" == "" (
  set mode=probe
  set "probedir=%1"
) else (
  set mode=file
)

if "%mode%" == "test" (

  echo Running standard tests...
  for /L %%i in (1,1,10) do (
    for %%a in (
      "terrain.step surfaces 1 1000000 500"
      "hammer.step surfaces 1-45 1000000 500"
      "sphere_nurbs.step surfaces 1 1000000 500"
    ) do (
      for %%o in ("sequential" "random") do (
        for /L %%d in (0,1,2) do (
          echo.
          echo =====================================================
          echo Iteration %%~i, case %%~a, %%~o, degree %%~d
          echo =====================================================
          %EXE% %DATA_DIR%/%%~a %%~o %%~d perf 2>>runs.log
        )
      )
    )
  )

) else if "%mode%" == "probe" (

  echo Probing files in %probedir%...

  echo NOT IMPLEMENTED YET

) else if "%mode%" == "file" (
  echo Executing nurbs_benchmark %*
  %EXE% %* 2>>runs.log
)

endlocal
